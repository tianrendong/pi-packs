{
  "name": "pi-qq",
  "version": "0.1.14",
  "description": "Ask side questions in pi without polluting the main transcript — /qq or alt+q.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-qq",
    "quick-question",
    "side-question",
    "context-aware",
    "transcript-safe",
    "history",
    "question",
    "shortcut",
    "keybinding",
    "overlay"
  ],
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --strict --skipLibCheck index.ts qq.ts qq-ui.ts"
  },
  "files": [
    "index.ts",
    "qq.ts",
    "qq-ui.ts",
    "prompts/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/jennyyu212/pi-qq-assets/main/assets/pi-qq-preview.png"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
