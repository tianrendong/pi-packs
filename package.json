{
  "name": "pi-packs",
  "version": "0.7.10",
  "description": "Umbrella Pi package: /install picker for a curated set of pi extensions (pi-qq, pi-chrome, pi-intercom, pi-linter, pi-bar, pi-prompt-shelf, pi-caveman).",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-packs",
    "pi-qq",
    "pi-chrome",
    "pi-intercom",
    "pi-linter",
    "pi-bar",
    "pi-prompt-shelf",
    "pi-caveman"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tianrendong/pi-packages.git"
  },
  "bugs": {
    "url": "https://github.com/tianrendong/pi-packages/issues"
  },
  "homepage": "https://github.com/tianrendong/pi-packages#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "extensions",
    "README.md"
  ],
  "scripts": {
    "pack:dry-run": "npm pack --dry-run"
  },
  "workspaces": [
    "packages/*"
  ],
  "pi-packs": {
    "installable": [
      { "name": "pi-qq", "description": "Ask side questions in an overlay." },
      { "name": "pi-chrome", "description": "Drive your existing Chrome profile." },
      { "name": "pi-intercom", "description": "Message other local Pi sessions." },
      { "name": "pi-linter", "description": "Lint prompt drafts before sending." },
      { "name": "pi-bar", "description": "Show model, thinking, and context in the footer." },
      { "name": "pi-prompt-shelf", "description": "Shelve and restore prompt drafts." },
      { "name": "pi-caveman", "description": "Make replies terse to save tokens." }
    ]
  },
  "pi": {
    "extensions": [
      "./extensions/install-command.ts"
    ]
  }
}
